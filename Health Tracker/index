<!DOCTYPE html>
<html class="light" lang="es">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport"/>
    <title>Health Route - Mi Salud</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;700;800&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <!-- SDK Oficial de Supabase para Web Estática -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        body {
            font-family: 'Public Sans', sans-serif;
            -webkit-tap-highlight-color: transparent;
            min-height: 100dvh;
            background: radial-gradient(circle at top left, #f0fdfa, #f8fafc);
            color: #131b2e;
            overflow-x: hidden;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 48;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05);
            transition: all 0.3s ease-in-out;
        }
        .glass-header {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.4);
        }
        .subtab-active {
            background-color: #006c49 !important;
            color: white !important;
        }
        .section-transition {
            transition: opacity 0.25s ease-in-out, transform 0.25s ease-in-out;
        }
        .section-hidden {
            display: none;
            opacity: 0;
            transform: translateY(10px);
        }
        .section-visible {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }
        .haptic-feedback:active {
            transform: scale(0.96);
            transition: transform 0.1s;
        }
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .modal-overlay {
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
        .btn-emerald-gradient {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.3);
        }
        .progress-ring-circle {
            transition: stroke-dashoffset 0.35s;
            transform: rotate(-90deg);
            transform-origin: 50% 50%;
        }
        .battery-level {
            transition: height 0.5s ease-out;
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#006c49",
                        "secondary": "#10b981",
                        "background": "#faf8ff",
                        "surface": "#ffffff",
                        "outline": "#6c7a71",
                        "on-surface": "#131b2e"
                    },
                    spacing: {
                        "touch-target-min": "56px",
                        "container-margin": "20px",
                        "card-padding": "20px"
                    }
                }
            }
        }
    </script>
</head>
<body class="text-slate-900">

<!-- MODAL MAESTRO DE AUTENTICACIÓN (LOGIN / REGISTRO) -->
<div class="fixed inset-0 z-[300] flex items-center justify-center p-4 modal-overlay transition-all duration-500" id="auth-modal">
    <div class="glass-card w-full max-w-md rounded-[2.5rem] p-6 border-white/50 shadow-2xl relative">
        <div class="text-center mb-6">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="material-symbols-outlined text-primary text-3xl">shield_person</span>
            </div>
            <h2 class="text-xl font-black text-slate-900 tracking-tight" id="auth-modal-title">Iniciar Sesión</h2>
            <p class="text-xs text-slate-500 mt-1" id="auth-modal-desc">Ingresa tus credenciales para acceder de forma segura a tu Ruta de Salud.</p>
        </div>

        <!-- Formulario Unificado -->
        <form id="auth-form" onsubmit="handleAuthSubmit(event)" class="space-y-4">
            <!-- Campo Nombre (Oculto por defecto en Login) -->
            <div class="hidden transition-all duration-300" id="auth-field-name">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-wider ml-1">Nombre Completo</label>
                <div class="relative mt-1">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">badge</span>
                    <input id="auth-input-name" class="w-full bg-white border border-slate-200 rounded-xl py-3 pl-10 pr-4 text-xs font-bold focus:ring-2 focus:ring-primary/20" type="text" placeholder="Ej: María Rodríguez"/>
                </div>
            </div>

            <!-- Campo Correo -->
            <div>
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-wider ml-1">Correo Electrónico</label>
                <div class="relative mt-1">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">mail</span>
                    <input id="auth-input-email" required class="w-full bg-white border border-slate-200 rounded-xl py-3 pl-10 pr-4 text-xs font-bold focus:ring-2 focus:ring-primary/20" type="email" placeholder="maria@ejemplo.com"/>
                </div>
            </div>

            <!-- Campo Contraseña -->
            <div>
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-wider ml-1">Contraseña</label>
                <div class="relative mt-1">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">lock</span>
                    <input id="auth-input-password" required class="w-full bg-white border border-slate-200 rounded-xl py-3 pl-10 pr-4 text-xs font-bold focus:ring-2 focus:ring-primary/20" type="password" placeholder="••••••••"/>
                </div>
            </div>

            <!-- Botón de Envío -->
            <button type="submit" id="auth-btn-submit" class="w-full btn-emerald-gradient text-white font-black py-4 rounded-xl haptic-feedback text-xs uppercase tracking-widest mt-2">
                Ingresar a la App
            </button>
        </form>

        <!-- Selector Alternativo de Flujo -->
        <div class="text-center mt-6 pt-4 border-t border-slate-200/50">
            <p class="text-xs text-slate-500 font-medium" id="auth-toggle-text">
                ¿No tienes una cuenta cuenta en HealthStars? 
                <button type="button" class="text-primary font-black ml-1 outline-none focus:underline" onclick="toggleAuthMode()">Regístrate aquí</button>
            </p>
        </div>
    </div>
</div>

<!-- Security Overlay (FaceID) -->
<div class="fixed inset-0 z-[200] hidden flex items-center justify-center p-6" id="security-overlay">
    <div class="absolute inset-0 modal-overlay" onclick="closeSecurity()"></div>
    <div class="glass-card w-full max-w-sm rounded-[2rem] p-8 relative z-[210] text-center border-white/40">
        <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-primary text-4xl">faceid</span>
        </div>
        <h3 class="text-xl font-extrabold text-slate-900 mb-2">Acceso Seguro</h3>
        <p class="text-sm text-slate-500 mb-8">Confirma tu identidad para generar y compartir tu informe clínico consolidado.</p>
        <button class="w-full btn-emerald-gradient text-white font-black py-4 rounded-2xl haptic-feedback mb-4" onclick="unlockAccess()">Confirmar con FaceID</button>
        <button class="text-slate-400 font-bold text-sm" onclick="closeSecurity()">Cancelar</button>
    </div>
</div>

<!-- SVGs -->
<svg style="display: none;">
    <symbol id="starry-happy" viewbox="0 0 200 200">
        <g>
            <path d="M 100 25 L 123.5 72.5 L 176 80 L 138 117 L 147 169.5 L 100 145 L 53 169.5 L 62 117 L 24 80 L 76.5 72.5 Z" fill="#facc15" stroke="#ca8a04" stroke-linejoin="round" stroke-width="2"></path>
            <circle cx="85" cy="100" fill="#422006" r="5"></circle>
            <circle cx="115" cy="100" fill="#422006" r="5"></circle>
            <path d="M 85 115 Q 100 125 115 115" fill="none" stroke="#422006" stroke-linecap="round" stroke-width="3"></path>
        </g>
    </symbol>
</svg>

<!-- Header -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-container-margin h-16 glass-header">
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full border-2 border-secondary overflow-hidden bg-white shadow-sm flex items-center justify-center text-primary font-bold text-sm" id="user-avatar-container">
            U
        </div>
        <h1 class="font-bold text-sm text-slate-900" id="header-title">Cargando Cuenta...</h1>
        <svg class="w-5 h-5"><use href="#starry-happy"></use></svg>
    </div>
    <button onclick="cerrarSesion()" class="material-symbols-outlined text-rose-500 text-xl haptic-feedback" title="Cerrar Sesión">logout</button>
</header>

<main class="pt-20 pb-32 px-container-margin min-h-screen">
    
    <!-- TAB 1: MI RUTA (Dashboard) -->
    <div class="section-transition section-visible space-y-6" id="section-mi-ruta">
        <!-- Astra AI Assistant Component -->
        <div class="glass-card p-6 rounded-[2.5rem] border-white/40">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-yellow-50 rounded-full flex items-center justify-center border border-yellow-100">
                    <svg class="w-6 h-6"><use href="#starry-happy"></use></svg>
                </div>
                <div>
                    <p class="text-[10px] font-black text-yellow-600 uppercase tracking-widest">Astra AI</p>
                    <p class="text-sm font-extrabold text-slate-900 leading-tight" id="astra-welcome-text">¡Hola! Soy Astra.</p>
                </div>
            </div>
            <div class="relative mb-4">
                <input class="w-full bg-white/50 border-none rounded-2xl py-4 pl-5 pr-12 text-sm font-medium focus:ring-2 focus:ring-primary/20" placeholder="¿Cómo te sientes hoy? Háblame o escribe..." type="text"/>
                <button class="absolute right-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-primary">mic</button>
            </div>
            <div class="flex gap-2 overflow-x-auto hide-scrollbar pb-1">
                <button class="whitespace-nowrap px-4 py-2 bg-white/60 border border-white/40 rounded-full text-[10px] font-black uppercase tracking-tight text-slate-600 haptic-feedback">🎙️ Dictar medicina nueva</button>
                <button class="whitespace-nowrap px-4 py-2 bg-white/60 border border-white/40 rounded-full text-[10px] font-black uppercase tracking-tight text-slate-600 haptic-feedback">📊 Ver mis últimas presiones</button>
                <button class="whitespace-nowrap px-4 py-2 bg-white/60 border border-white/40 rounded-full text-[10px] font-black uppercase tracking-tight text-slate-600 haptic-feedback">📤 Preparar reporte para el Dr.</button>
            </div>
        </div>

        <!-- Comandante de Salud Card -->
        <div class="glass-card p-6 rounded-[2.5rem] bg-gradient-to-br from-emerald-600 to-emerald-800 text-white border-none relative overflow-hidden">
            <div class="relative z-10">
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <h3 class="text-xs font-black uppercase tracking-[0.2em] opacity-80 mb-1">Comandante de Salud</h3>
                        <p class="text-3xl font-black">2,450 PTS</p>
                    </div>
                    <span class="material-symbols-outlined text-4xl opacity-50">workspace_premium</span>
                </div>
                <div class="w-full bg-white/20 h-2 rounded-full overflow-hidden">
                    <div class="bg-white h-full w-[75%] rounded-full shadow-[0_0_10px_rgba(255,255,255,0.5)]"></div>
                </div>
                <p class="text-[10px] font-bold mt-3 opacity-80">¡Estás a 550 pts de subir a Capitana!</p>
            </div>
        </div>

        <!-- Interactive Gauges -->
        <div class="grid grid-cols-2 gap-4">
            <div class="glass-card p-5 rounded-[2rem] flex flex-col items-center text-center">
                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-4">Batería Humana</p>
                <div class="w-12 h-20 border-4 border-slate-200 rounded-xl relative p-1 mb-3">
                    <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-5 h-2 bg-slate-200 rounded-t-md"></div>
                    <div class="w-full h-full bg-slate-50 rounded-md overflow-hidden flex flex-col justify-end">
                        <div class="bg-emerald-500 w-full battery-level" style="height: 65%;"></div>
                    </div>
                </div>
                <p class="text-xl font-black text-emerald-600 leading-none">65%</p>
                <p class="text-[8px] font-bold text-slate-400 mt-1 uppercase">Buen Nivel</p>
            </div>
            <div class="glass-card p-5 rounded-[2rem] flex flex-col items-center text-center">
                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-4">Medidor de Calma</p>
                <div class="w-20 h-20 relative">
                    <svg class="w-full h-full" viewbox="0 0 100 100">
                        <circle cx="50" cy="50" fill="none" r="40" stroke="#f1f5f9" stroke-width="10"></circle>
                        <circle cx="50" cy="50" fill="none" r="40" stroke="#0ea5e9" stroke-dasharray="251" stroke-dashoffset="180" stroke-linecap="round" stroke-width="10"></circle>
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center">
                        <span class="material-symbols-outlined text-sky-500">air</span>
                    </div>
                </div>
                <p class="text-xl font-black text-sky-600 leading-none mt-3">82%</p>
                <p class="text-[8px] font-bold text-slate-400 mt-1 uppercase">Turbulencia Baja</p>
            </div>
        </div>
    </div>

    <!-- TAB 2: HISTORIAL CLINICO -->
    <div class="section-transition section-hidden space-y-6" id="section-historial">
        <div class="flex glass-card p-1 rounded-2xl overflow-x-auto hide-scrollbar">
            <button class="flex-1 px-4 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all subtab-active duration-300" id="tab-btn-historial-clinica" onclick="switchHistorialSubTab('clinica')">Historial Clínico</button>
            <button class="flex-1 px-4 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest text-slate-400 transition-all duration-300" id="tab-btn-historial-diario" onclick="switchHistorialSubTab('diario')">Bitácora en Casa</button>
        </div>

        <!-- SUB-TAB A: Historial Clínico Base -->
        <div class="space-y-6" id="historial-clinica">
            <div class="space-y-3">
                <h4 class="text-[10px] font-black text-slate-400 tracking-[0.2em] px-2 uppercase">GPS VITAL (Últimos Registros)</h4>
                <div class="grid grid-cols-2 gap-4">
                    <div class="glass-card p-4 rounded-3xl relative">
                        <div class="flex justify-between items-start mb-2">
                            <span class="text-[9px] font-black text-slate-400 uppercase">Glucosa</span>
                            <span class="text-[7px] font-black bg-emerald-100 text-emerald-700 px-1.5 py-0.5 rounded">Hoy, 7:15 AM</span>
                        </div>
                        <p class="text-2xl font-black text-slate-900">105 <span class="text-xs font-bold text-slate-400">mg/dL</span></p>
                    </div>
                    <div class="glass-card p-4 rounded-3xl relative">
                        <div class="flex justify-between items-start mb-2">
                            <span class="text-[9px] font-black text-slate-400 uppercase">Presión</span>
                            <span class="text-[7px] font-black bg-emerald-100 text-emerald-700 px-1.5 py-0.5 rounded">Hoy, 7:15 AM</span>
                        </div>
                        <p class="text-2xl font-black text-slate-900">118/76 <span class="text-xs font-bold text-slate-400">mmHg</span></p>
                    </div>
                </div>
            </div>

            <div class="glass-card p-6 rounded-[2.5rem]">
                <h4 class="text-[10px] font-black text-slate-400 tracking-[0.2em] mb-6 uppercase text-center">ANÁLISIS DE PESO COHORTES</h4>
                <div class="flex items-center justify-around mb-6">
                    <div class="text-center">
                        <p class="text-[9px] font-black text-slate-400 uppercase">Altura Fija</p>
                        <p class="text-lg font-black text-slate-500">1.68 m</p>
                    </div>
                    <div class="relative w-28 h-28">
                        <svg class="w-full h-full" viewbox="0 0 100 100">
                            <circle cx="50" cy="50" fill="none" r="42" stroke="#f1f5f9" stroke-width="6"></circle>
                            <circle cx="50" cy="50" fill="none" r="42" stroke="#eab308" stroke-dasharray="263" stroke-dashoffset="90" stroke-linecap="round" stroke-width="6"></circle>
                        </svg>
                        <div class="absolute inset-0 flex flex-col items-center justify-center">
                            <span class="text-[9px] font-black text-slate-400 uppercase">IMC Actual</span>
                            <span class="text-xl font-black text-amber-500">24.2</span>
                        </div>
                    </div>
                    <div class="text-center">
                        <p class="text-[9px] font-black text-slate-400 uppercase">Peso Actual</p>
                        <input class="w-20 bg-white/60 border border-slate-200 text-center text-lg font-black text-primary py-1 px-2 rounded-xl focus:ring-2 focus:ring-primary/20" type="text" value="68.5"/>
                        <p class="text-[8px] font-bold text-slate-400 mt-1">kg</p>
                    </div>
                </div>
                <div class="bg-slate-100 rounded-2xl p-3 text-center border border-slate-200/50">
                    <p class="text-xs font-extrabold text-slate-700">🎯 Tu Meta de Estabilización</p>
                    <p class="text-[11px] text-slate-500 font-medium mt-1">Debes bajar <span class="text-primary font-black">3.5 kg</span> para ingresar al IMC Óptimo Verde (22.0)</p>
                </div>
            </div>

            <div class="space-y-4">
                <h4 class="text-[10px] font-black text-slate-400 tracking-[0.2em] px-2 uppercase">REPORTE OFICIAL DE LABORATORIO</h4>
                <div class="glass-card p-6 rounded-[2.5rem] space-y-4">
                    <button type="button" class="w-full py-4 border-2 border-dashed border-primary/30 bg-primary/5 rounded-2xl text-primary font-black text-xs uppercase tracking-wider flex items-center justify-center gap-2 haptic-feedback mb-2">
                        <span class="material-symbols-outlined text-xl">lab_research</span>
                        <span>📸 Escanear Laboratorio con IA</span>
                    </button>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[9px] font-black text-slate-400 uppercase">Hemoglobina Glicosilada (HbA1c)</label>
                            <input class="w-full bg-white/50 border-none rounded-lg text-xs font-bold mt-1" type="text" value="6.1 %"/>
                        </div>
                        <div>
                            <label class="text-[9px] font-black text-slate-400 uppercase">Colesterol Total</label>
                            <input class="w-full bg-white/50 border-none rounded-lg text-xs font-bold mt-1" type="text" value="180 mg/dL"/>
                        </div>
                        <div class="col-span-2">
                            <label class="text-[9px] font-black text-slate-400 uppercase">Triglicéridos</label>
                            <input class="w-full bg-white/50 border-none rounded-lg text-xs font-bold mt-1" type="text" value="145 mg/dL"/>
                        </div>
                        <div>
                            <label class="text-[9px] font-black text-slate-400 uppercase">Fecha del Examen</label>
                            <input class="w-full bg-white/50 border-none rounded-lg text-xs font-bold mt-1" type="text" value="20/06/2026"/>
                        </div>
                        <div>
                            <label class="text-[9px] font-black text-slate-400 uppercase">Laboratorio / Procedencia</label>
                            <input class="w-full bg-white/50 border-none rounded-lg text-xs font-bold mt-1" type="text" value="Laboratorio Raly (Panamá)"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SUB-TAB B: Bitácora en Casa -->
        <div class="space-y-4 hidden" id="historial-diario">
            <h4 class="text-[10px] font-black text-slate-400 tracking-[0.2em] px-2 uppercase">Frecuencia de Monitoreo Doméstico</h4>
            <div class="glass-card p-6 rounded-[2.5rem] space-y-4">
                <div class="p-4 bg-white/50 rounded-2xl border border-slate-100 flex flex-col gap-2">
                    <div class="flex justify-between items-center">
                        <span class="text-xs font-black text-slate-800">🩸 Glucosa Capilar</span>
                        <span class="text-[8px] font-bold bg-amber-100 text-amber-700 px-2 py-0.5 rounded uppercase">Ayunas / Postprandial</span>
                    </div>
                    <div class="flex items-center gap-2 mt-1">
                        <input class="flex-1 bg-white border border-slate-200 rounded-xl py-2 px-3 text-sm font-bold" placeholder="Escribe o habla..." type="text" value="105 mg/dL"/>
                        <button class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center material-symbols-outlined text-slate-500 haptic-feedback">mic</button>
                        <button class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center material-symbols-outlined text-slate-500 haptic-feedback">photo_camera</button>
                    </div>
                </div>
                <div class="p-4 bg-white/50 rounded-2xl border border-slate-100 flex flex-col gap-2">
                    <div class="flex justify-between items-center">
                        <span class="text-xs font-black text-slate-800">🫀 Presión Arterial</span>
                        <span class="text-[8px] font-bold bg-amber-100 text-amber-700 px-2 py-0.5 rounded uppercase">Mañana y Noche</span>
                    </div>
                    <div class="flex items-center gap-2 mt-1">
                        <input class="flex-1 bg-white border border-slate-200 rounded-xl py-2 px-3 text-sm font-bold" placeholder="Escribe o habla..." type="text" value="118/76 mmHg"/>
                        <button class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center material-symbols-outlined text-slate-500 haptic-feedback">mic</button>
                        <button class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center material-symbols-outlined text-slate-500 haptic-feedback">photo_camera</button>
                    </div>
                </div>
                <div class="p-4 bg-white/50 rounded-2xl border border-slate-100 flex flex-col gap-2">
                    <div class="flex justify-between items-center">
                        <span class="text-xs font-black text-slate-800">🫁 Oxigenación y Pulso</span>
                        <span class="text-[8px] font-bold bg-slate-100 text-slate-500 px-2 py-0.5 rounded uppercase">Al sentir fatiga</span>
                    </div>
                    <div class="flex items-center gap-2 mt-1">
                        <input class="flex-1 bg-white border border-slate-200 rounded-xl py-2 px-3 text-sm font-bold" placeholder="Escribe valor..." type="text" value="98 %"/>
                    </div>
                </div>
                <div class="p-4 bg-white/50 rounded-2xl border border-slate-100 flex flex-col gap-2">
                    <div class="flex justify-between items-center">
                        <span class="text-xs font-black text-slate-800">📏 Circunferencia Abdominal</span>
