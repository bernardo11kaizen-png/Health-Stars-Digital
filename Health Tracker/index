<script>
    // ==========================================
    // 1. CONFIGURACIÓN E INICIALIZACIÓN SUPABASE
    // ==========================================
    // REEMPLAZA ESTAS DOS VARIABLES CON TUS DATOS DE SUPABASE DE UNA VEZ
   const SUPABASE_URL = "https://ydkykhkbvqjzxkaqxakg.supabase.co"; 
   const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inlka3lraGtidnFqenhrYXF4YWtnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI5ODM1MjksImV4cCI6MjA5ODU1OTUyOX0.tOUOjrBjNex4afmDu1lk9higsFNKxBzZACKp8uK7nOw";
    
    let supabaseClient = null;
    let usuarioConectado = null;
    let isRegisterMode = false; // Controla si el modal está en login o registro

    // Intentar inicializar de forma segura si las llaves están configuradas
    try {
        if (!SUPABASE_URL.includes("TU_PROYECTO")) {
            supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
        }
    } catch(e) { console.error("Error inicializando Supabase: ", e); }

    window.addEventListener('DOMContentLoaded', async () => {
        // Verificar sesión activa al cargar
        if (supabaseClient) {
            const { data: { session } } = await supabaseClient.auth.getSession();
            if (session) {
                setupLoggedInUser(session.user);
            } else {
                showAuthModal();
            }
        } else {
            // Modo simulación si no se ha conectado Supabase aún
            setupMockUser();
        }
    });

    // ==========================================
    // 2. LÓGICA DE INTERFAZ DEL MODAL DE AUTENTICACIÓN
    // ==========================================
    function showAuthModal() {
        document.getElementById('auth-modal').classList.remove('hidden');
    }

    function hideAuthModal() {
        document.getElementById('auth-modal').classList.add('hidden');
    }

    function toggleAuthMode() {
        isRegisterMode = !isRegisterMode;
        const nameField = document.getElementById('auth-field-name');
        const title = document.getElementById('auth-modal-title');
        const desc = document.getElementById('auth-modal-desc');
        const submitBtn = document.getElementById('auth-btn-submit');
        const toggleText = document.getElementById('auth-toggle-text');

        if (isRegisterMode) {
            nameField.classList.remove('hidden');
            document.getElementById('auth-input-name').required = true;
            title.innerText = "Crear Cuenta Médica";
            desc.innerText = "Regístrate en HealthStars para asegurar tu tratamiento SFT.";
            submitBtn.innerText = "Registrarse y Crear Ruta";
            toggleText.innerHTML = `¿Ya tienes cuenta? <button type="button" class="text-primary font-black ml-1 outline-none focus:underline" onclick="toggleAuthMode()">Inicia sesión aquí</button>`;
        } else {
            nameField.classList.add('hidden');
            document.getElementById('auth-input-name').required = false;
            title.innerText = "Iniciar Sesión";
            desc.innerText = "Ingresa tus credenciales para acceder de forma segura a tu Ruta de Salud.";
            submitBtn.innerText = "Ingresar a la App";
            toggleText.innerHTML = `¿No tienes una cuenta? <button type="button" class="text-primary font-black ml-1 outline-none focus:underline" onclick="toggleAuthMode()">Regístrate aquí</button>`;
        }
    }

    // Manejador del Envío del Formulario
    async function handleAuthSubmit(event) {
        event.preventDefault();
        const email = document.getElementById('auth-input-email').value;
        const password = document.getElementById('auth-input-password').value;

        if (!supabaseClient) {
            // Fallback para probar en local sin Supabase configurado
            const mockName = isRegisterMode ? document.getElementById('auth-input-name').value : "María Rodríguez";
            alert("⚠️ Modo Simulación: Supabase no conectado. Inicializando con perfil de " + mockName);
            setupMockUser(mockName);
            hideAuthModal();
            return;
        }

        if (isRegisterMode) {
            const nombre = document.getElementById('auth-input-name').value;
            const { data, error } = await supabaseClient.auth.signUp({
                email, password, options: { data: { nombre: nombre } }
            });
            if (error) alert("Error en registro: " + error.message);
            else {
                alert("¡Registro exitoso! Te enviamos un correo de confirmación.");
                if (data.user) setupLoggedInUser(data.user);
                hideAuthModal();
            }
        } else {
            const { data, error } = await supabaseClient.auth.signInWithPassword({ email, password });
            if (error) alert("Credenciales incorrectas: " + error.message);
            else {
                setupLoggedInUser(data.user);
                hideAuthModal();
            }
        }
    }

    function setupLoggedInUser(user) {
        usuarioConectado = user;
        const userRealName = user.user_metadata?.nombre || "Usuario";
        document.getElementById('header-title').innerText = "Ruta: " + userRealName;
        document.getElementById('astra-welcome-text').innerText = "¡Hola " + userRealName.split(' ')[0] + "! Soy Astra.";
        document.getElementById('user-avatar-container').innerText = userRealName.charAt(0).toUpperCase();
        document.getElementById('botiquin-counter-text').innerText = "📋 Conectado al Botiquín de " + userRealName.split(' ')[0];
    }

    function setupMockUser(name = "María Rodríguez") {
        document.getElementById('header-title').innerText = "Demo: " + name;
        document.getElementById('astra-welcome-text').innerText = "¡Hola " + name.split(' ')[0] + "! Soy Astra.";
        document.getElementById('user-avatar-container').innerText = name.charAt(0).toUpperCase();
        document.getElementById('botiquin-counter-text').innerText = "📋 Tienes 3 medicamentos activos (Perfil Demo)";
        hideAuthModal();
    }

    async function cerrarSesion() {
        if (supabaseClient) {
            await supabaseClient.auth.signOut();
        }
        usuarioConectado = null;
        alert("Sesión cerrada.");
        window.location.reload();
    }

    // ==========================================
    // 3. NAVEGACIÓN Y TABS COMPORTAMIENTO
    // ==========================================
    function navigate(sectionId) {
        switchTab(sectionId);
    }

    function switchTab(sectionId) {
        const sections = ['mi-ruta', 'historial', 'mis-pastillas', 'soporte'];
        const titles = {
            'mi-ruta': 'Mi Salud',
            'historial': 'Historial Clínico',
            'mis-pastillas': 'Mis Medicinas',
            'soporte': 'Soporte Directo'
        };

        sections.forEach(s => {
            const el = document.getElementById('section-' + s);
            const indicator = document.getElementById('nav-indicator-' + s);
            const btn = document.getElementById('nav-' + s);
            const label = btn.querySelector('span:last-child');
            const icon = indicator.querySelector('.material-symbols-outlined');

            if (s === sectionId) {
                el.classList.remove('section-hidden');
                el.classList.add('section-visible');
                indicator.classList.replace('text-slate-500', 'text-primary');
                label.classList.replace('text-slate-500', 'text-primary');
                icon.style.fontVariationSettings = "'FILL' 1";
            } else {
                el.classList.add('section-hidden');
                el.classList.remove('section-visible');
                indicator.classList.replace('text-primary', 'text-slate-500');
                label.classList.replace('text-primary', 'text-slate-500');
                icon.style.fontVariationSettings = "'FILL' 0";
            }
        });

        // Solo sobreescribir título si no está el nombre del usuario
        if(!usuarioConectado) {
            document.getElementById('header-title').innerText = titles[sectionId];
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function switchPillsTab(tab) {
        ['rpm', 'diario', 'calendario'].forEach(t => {
            const btn = document.getElementById('tab-btn-pills-' + t);
            const content = document.getElementById('pills-' + t);
            if(t === tab) {
                btn.classList.add('subtab-active');
                btn.classList.remove('text-slate-400');
                content.classList.remove('hidden');
            } else {
                btn.classList.remove('subtab-active');
                btn.classList.add('text-slate-400');
                content.classList.add('hidden');
            }
        });
    }

    function switchHistorialSubTab(tab) {
        ['clinica', 'diario'].forEach(t => {
            const btn = document.getElementById('tab-btn-historial-' + t);
            const content = document.getElementById('historial-' + t);
            if(t === tab) {
                btn.classList.add('subtab-active');
                btn.classList.remove('text-slate-400');
                content.classList.remove('hidden');
            } else {
                btn.classList.remove('subtab-active');
                btn.classList.add('text-slate-400');
                content.classList.add('hidden');
            }
        });
    }

    function switchSupportTab(tab) {
        ['consul', 'chat'].forEach(t => {
            const btn = document.getElementById('tab-btn-support-' + t);
            const content = document.getElementById('support-' + t);
            if(t === tab) {
                btn.classList.add('subtab-active');
                btn.classList.remove('text-slate-400');
                content.classList.remove('hidden');
            } else {
                btn.classList.remove('subtab-active');
                btn.classList.add('text-slate-400');
                content.classList.add('hidden');
            }
        });
    }

    // ==========================================
    // 4. FLUJO DE EXPORTACIÓN Y SEGURIDAD BIOMÉTRICA
    // ==========================================
    let securityCallback = null;
    function promptSecurity(callback) {
        securityCallback = callback;
        document.getElementById('security-overlay').classList.remove('hidden');
    }

    function unlockAccess() {
        document.getElementById('security-overlay').classList.add('hidden');
        alert("🔒 ¡Identidad confirmada mediante FaceID! Reporte Maestro SFT PDF generado con éxito. Abriendo WhatsApp para compartir...");
        if (securityCallback) securityCallback();
        securityCallback = null;
    }

    function closeSecurity() {
        document.getElementById('security-overlay').classList.add('hidden');
        securityCallback = null;
    }

    // Inicializaciones secundarias
    switchPillsTab('rpm');
    switchHistorialSubTab('clinica');
</script>
